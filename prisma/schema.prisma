generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  whatsapp  String    @unique
  payments  Payment[]
  licenses  License[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Plan {
  id           String    @id @default(cuid())
  name         String
  price        Float
  durationDays Int?      // null = lifetime
  licenses     License[]
}

model Payment {
  id           String        @id @default(cuid())
  client       Client        @relation(fields: [clientId], references: [id])
  clientId     String
  amount       Float
  status       PaymentStatus @default(PENDING)
  mpPaymentId  String?       @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model License {
  id        String        @id @default(cuid())
  client    Client        @relation(fields: [clientId], references: [id])
  clientId  String
  plan      Plan          @relation(fields: [planId], references: [id])
  planId    String
  key       String        @unique
  status    LicenseStatus @default(ACTIVE)
  expiresAt DateTime?     // null = lifetime
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Settings {
  id                String   @id @default("global")
  extensionUrl      String   @default("https://mega2ai.com/download/mega_2ai_v2.zip")
  customerGroupName String   @default("Grupo VIP de Alunos")
  customerGroupUrl  String   @default("https://chat.whatsapp.com/exemplo-clientes")
  communityGroupName String  @default("Comunidade Mega_2ai")
  communityGroupUrl String   @default("https://chat.whatsapp.com/exemplo-comunidade")
  videoUrl          String   @default("https://youtube.com/link-do-tutorial")
  updatedAt         DateTime @updatedAt
}

enum PaymentStatus {
  PENDING
  APPROVED
  FAILED
  REFUNDED
}

enum LicenseStatus {
  ACTIVE
  EXPIRED
  REVOKED
}
